# ── LLM Provider ──────────────────────────────────────────────
# Options: anthropic | openai | ollama | openrouter
LLM_PROVIDER=anthropic

# ── API Keys (set the one matching your provider) ─────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# OLLAMA_HOST=http://localhost:11434

# ── Models (defaults shown — override for your provider) ──────
# BRIDGE_MODEL=claude-sonnet-4-6
# BRIDGE_MODEL_FAST=claude-haiku-4-5-20251001

# ── Server ────────────────────────────────────────────────────
PORT=8000
# BUILD_TOKEN=your-secret-token-here

# ── Intervals ─────────────────────────────────────────────────
# BRIDGE_HEARTBEAT_MIN=30
# SUBSTRATE_INTERVAL=300
# BRIDGE_MAX_TOKENS=4096
